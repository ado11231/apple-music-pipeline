#!/usr/bin/env bash
#
# addsong: download a song from a URL (or YouTube search) and have it
# auto-import into Apple Music on macOS / Windows, or saved to a folder on
# Linux (no Apple Music app there).
#
#   addsong "https://www.youtube.com/watch?v=..."          single track (URL)
#   addsong "queen bohemian rhapsody"                       top YouTube result
#   addsong --search 3 "80s disco mix"                      top 3 results
#   addsong --playlist "https://www.youtube.com/playlist?list=..."
#   addsong subscribe "https://www.youtube.com/playlist?list=..."
#   addsong sync                                            # import new tracks from every subscription
#
# Pipeline (per track):
#   1. read the scraped title/uploader (no download yet)
#   2. clean it up (strip "(Official Video)", "[4K]"; split "Artist - Title")
#   3. show it and let you accept or edit the artist/title (interactive runs)
#   4. skip it if it was imported before (duplicate guard)
#   5. yt-dlp downloads the audio; ffmpeg embeds artwork and your chosen tags
#   6. move the tagged file into the watch folder (Apple Music / iTunes / output)
#
# See the README (Setup) and ARCHITECTURE.md for the full design.

set -euo pipefail

# ---------------------------------------------------------------------------
# Config (all overridable via environment)
# ---------------------------------------------------------------------------

VERSION="1.3.0"

# Load defaults from a config file of KEY=VALUE lines (parsed, not sourced, so it
# can't run arbitrary code). Only ADDSONG_* keys are honored, and a value already
# set in the environment always wins over the file.
CONFIG_FILE="${ADDSONG_CONFIG:-$HOME/.config/addsong/config}"
if [[ -f "$CONFIG_FILE" ]]; then
  while IFS='=' read -r _k _v; do
    _k="${_k//[[:space:]]/}"
    [[ -z "$_k" || "$_k" == \#* || "$_k" != ADDSONG_* ]] && continue
    _v="${_v#"${_v%%[![:space:]]*}"}"   # trim leading whitespace
    _v="${_v%\"}"; _v="${_v#\"}"        # strip surrounding double quotes
    _v="${_v%\'}"; _v="${_v#\'}"        # strip surrounding single quotes
    [[ -z "${!_k+set}" ]] && export "$_k=$_v"
  done < "$CONFIG_FILE"
  unset _k _v
fi

# Watch folder is OS-dependent; the default is computed in main() via
# default_watch_dir() so the helper can probe per platform. ADDSONG_WATCH_DIR
# (if set) always wins.
WATCH_DIR=""
AUDIO_FORMAT="${ADDSONG_AUDIO_FORMAT:-m4a}"
# yt-dlp VBR quality for the extracted audio: 0 (best) .. 10 (worst). Overridable
# per run with --quality; the env var sets the default.
AUDIO_QUALITY="${ADDSONG_AUDIO_QUALITY:-0}"
# Audio formats accepted by --format. Limited to formats whose yt-dlp
# --audio-format name equals the output file extension, since the importer
# looks the staged file up as "<id>.<format>" (e.g. vorbis->.ogg, alac->.m4a,
# best->varies would break that, so they're intentionally excluded).
AUDIO_FORMATS='m4a mp3 flac opus wav aac'
# Ledger of already-imported tracks, keyed by video id (duplicate detection).
LEDGER="${ADDSONG_LEDGER:-$HOME/.local/state/addsong/imported.tsv}"
# Subscribed playlists (one URL per line, # comments allowed). 'sync' expands
# each and the ledger dedups already-imported tracks -- the subscription file
# holds URLs only, no "last seen" marker.
SUBSCRIPTIONS="${ADDSONG_SUBSCRIPTIONS:-$HOME/.local/state/addsong/subscribed.tsv}"
# Retry behavior for transient (network) yt-dlp failures.
RETRIES="${ADDSONG_RETRIES:-2}"          # extra attempts after the first
RETRY_DELAY="${ADDSONG_RETRY_DELAY:-3}"  # base backoff seconds (grows per attempt)

# yt-dlp errors that are permanent: never worth retrying.
YTDLP_HARD_ERRORS='private video|members-only|members only|video unavailable|this video is unavailable|is unavailable|has been removed|removed by the user|has been terminated|account.*terminated|confirm your age|age-restricted|sign in to confirm|not available in your country|not available on this app|blocked it in your country|copyright'

PROG="$(basename "$0")"

# Flags
PLAYLIST=0      # --playlist: expand a playlist URL into individual tracks
ASSUME_YES=0    # -y/--yes:   never prompt; accept scraped/cleaned metadata
EDIT_FORCE=0    # --edit:     always prompt to review (even in playlists)
FORCE=0         # --force:    import even if the track is already in the ledger
DRYRUN=0        # --dry-run:  resolve and show metadata; download/import nothing
FROM_FILE=""    # --from F:   read URLs (one per line) from a file, or - for stdin
SEARCH=0        # --search N: treat the arg as a free-text YouTube search (N results)
SUBCMD=""       # the keyword verb (subscribe/unsubscribe/list/sync/clear-ledger) when present
QUIET=0         # --quiet:   suppress non-error info banners and status lines
VERBOSE=0       # --verbose: surface yt-dlp/ffmpeg stderr
NO_COLOR_FLAG=0 # --no-color: explicitly disable colored output
NOTIFY=0        # --notify:  fire a desktop notification per added track + batch
case "${ADDSONG_NOTIFY:-}" in 1|true|yes|on) NOTIFY=1 ;; esac

# Paint yt-dlp's real percent/speed/ETA bar for the download step. On by
# default; needs a TTY (falls back to the indeterminate spinner without one,
# or under --quiet/--verbose). Disable with --no-progress or ADDSONG_PROGRESS=0.
PROGRESS=1      # download bar; --no-progress / ADDSONG_PROGRESS=0 turns it off
case "${ADDSONG_PROGRESS:-}" in 0|false|no|off) PROGRESS=0 ;; esac

# Tallies for the end-of-run summary
N_ADDED=0
N_SKIPPED=0
N_FAILED=0

have_tty=0   # set in main(); declared here so it is defined when sourced
OS_MODE=""   # ditto (mac / win / wsl / linux / other)

# --- Colors / verbosity (set up in main once preflight runs) ----------------
# Defaults leave all ANSI codes empty so the pure helpers below never emit
# escape sequences -- tests or pipes see plain text. setup_colors() turns
# them on only when stdout/stderr are a TTY, NO_COLOR isn't set, and
# --no-color isn't requested (https://no-color.org/).
C_ERR=""; C_S_ADDED=""; C_S_SKIPPED=""; C_S_FAILED=""; C_RESET=""
# Extra accents used by the polished interactive output: a cyan accent (banners,
# headers, the Edit key), a dim shade (field labels, hints) and a bold prompt.
C_ACCENT=""; C_DIM=""; C_PROMPT=""; C_BOLD=""
# Per-field accents for the review card: the Artist and Title labels get their
# own colors, and the edit hint is shown in blue. Empty until setup_colors().
C_ARTIST=""; C_TITLE=""; C_HINT=""; C_HEADER=""
# Status/error glyphs and the banner prefix. All empty by default so the
# no-color / non-TTY / piped paths emit exactly the same plain text as before;
# setup_colors() fills them in only when colored output is enabled.
I_ADDED=""; I_SKIP=""; I_FAIL=""; I_ERR=""; GLYPH_NOTE=""; PFX_BANNER=""
# Progress-bar colors: a green fill (the growing rectangle) over a gray track.
# Empty by default so the no-color path falls back to plain block characters.
C_BAR_FILL=""; C_BAR_TRACK=""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

err()    { printf '%s%s%s:%s %s\n' "$C_ERR" "$I_ERR" "$PROG" "$C_RESET" "$*" >&2; }
die()    { err "$*"; exit 1; }
# Non-error info line (also to stderr); suppressed by --quiet. Used for
# banners like "Searching YouTube for:" or "Syncing:".
say()    { [[ "$QUIET" -eq 1 ]] || printf '%s\n' "$*" >&2; }
# Aligned one-line result, e.g.  "Added    Artist - Title".
# Caller passes a known keyword ("Added"/"Skipped"/"Would add"/...) -- we
# color the common ones. Suppressed under --quiet.
status() {
  [[ "$QUIET" -eq 1 ]] && return 0
  local keyword="$1" rest="$2" kcolor="" icon=""
  case "$keyword" in
    Added*|"Would add"*|Subscribed:*) kcolor="$C_S_ADDED";   icon="$I_ADDED" ;;
    Skipped*|Already*|*subscribed*)   kcolor="$C_S_SKIPPED"; icon="$I_SKIP"  ;;
    Failed*)                          kcolor="$C_S_FAILED";  icon="$I_FAIL"  ;;
  esac
  # When colored, `icon` carries the glyph + a space (and is empty otherwise),
  # so the no-color output is byte-for-byte the same aligned line as before.
  printf '  %s%s%-8s%s %s\n' "$kcolor" "$icon" "$keyword" "$C_RESET" "$rest"
}

# Fire a desktop notification (best effort). No-op unless --notify /
# ADDSONG_NOTIFY is set, and silently does nothing when no notifier is
# installed (terminal-notifier/osascript on macOS, notify-send elsewhere).
#   $1 = title, $2 = body
notify() {
  [[ "$NOTIFY" -eq 1 ]] || return 0
  local title="$1" body="$2"
  case "${OS_MODE:-}" in
    mac)
      if command -v terminal-notifier >/dev/null 2>&1; then
        terminal-notifier -title "$title" -message "$body" >/dev/null 2>&1 || true
      elif command -v osascript >/dev/null 2>&1; then
        local t="${title//\"/\\\"}" b="${body//\"/\\\"}"   # escape quotes for AppleScript
        osascript -e "display notification \"$b\" with title \"$t\"" >/dev/null 2>&1 || true
      fi
      ;;
    *)
      # Linux / WSL / Windows / other: notify-send if it exists.
      command -v notify-send >/dev/null 2>&1 \
        && notify-send "$title" "$body" >/dev/null 2>&1 || true
      ;;
  esac
  return 0
}

# Decide whether to colorize. Honors --no-color, NO_COLOR env, and non-TTY.
setup_colors() {
  if [[ "$NO_COLOR_FLAG" -eq 1 || -n "${NO_COLOR:-}" || "$have_tty" -eq 0 ]]; then
    return 0
  fi
  C_ERR=$'\033[1;31m'      # bold red -- "progname:" error prefix
  C_S_ADDED=$'\033[1;32m'  # bold green
  C_S_SKIPPED=$'\033[33m'  # yellow
  C_S_FAILED=$'\033[1;31m' # bold red
  C_RESET=$'\033[0m'
  C_ACCENT=$'\033[36m'     # cyan -- banners, the review header, the Edit key
  C_DIM=$'\033[2m'         # dim -- field labels and inline hints
  C_PROMPT=$'\033[1;36m'   # bold cyan -- the interactive prompt glyph
  C_BOLD=$'\033[1m'        # bold -- the song title in the review card
  C_ARTIST=$'\033[35m'     # magenta -- the "Artist" field label
  C_TITLE=$'\033[36m'      # cyan -- the "Title" field label
  C_HINT=$'\033[34m'       # blue -- the "blank keeps the current value" hint
  C_HEADER=$'\033[1;97m'   # bold bright-white -- the "Review track" card header
  C_BAR_FILL=$'\033[42m'   # green background -- the growing rectangle
  C_BAR_TRACK=$'\033[100m' # bright-black (gray) background -- the track behind it

  # Result glyphs (trailing space included so the keyword still aligns), the
  # error mark, a music note for the review header, and the banner prefix.
  I_ADDED='✓ '
  I_SKIP='• '
  I_FAIL='✗ '
  I_ERR='✗ '
  GLYPH_NOTE='♪'
  PFX_BANNER="${C_ACCENT}»${C_RESET} "
}

usage() {
  cat <<EOF
$PROG: download a song and auto-import it into Apple Music.

USAGE:
    $PROG [options] <url-or-query>
    $PROG subscribe <playlist-url>      subscribe to a playlist
    $PROG unsubscribe <playlist-url>    drop a subscription
    $PROG list                          show subscribed playlists
    $PROG sync [options]                import new tracks from every subscription
    $PROG clear-ledger [-y]             forget every imported track (reset dedup)
    $PROG --help

SUBCOMMANDS:
    subscribe <url>    Remember a playlist URL for repeat syncs.
    unsubscribe <url>  Forget a playlist URL.
    list              Print the currently subscribed playlist URLs.
    sync               Re-import any new tracks from each subscribed playlist
                      (already-imported tracks are skipped via the ledger, so
                      running it daily keeps your library in step with a
                      YouTube playlist for free). Composes with --force,
                      --dry-run, --edit, -y.
    clear-ledger       Forget every imported track by clearing the dedup
                      ledger, so future adds/syncs treat each track as new
                      again. Prompts to confirm at a terminal; pass -y to skip
                      the prompt (required when there's no terminal).

OPTIONS:
    --playlist        Treat the URL as a playlist and import every track.
    --from FILE       Read URLs (one per line) from FILE, or - for stdin.
    --search N        Treat the argument as a free-text YouTube search and
                      import the top N results (1-50; default 1 when the
                      argument is not a URL). No new dependencies.
    -y, --yes         Don't prompt; accept the scraped/cleaned metadata as-is.
    --edit            Always prompt to review metadata (even for playlists).
    --force           Import even if this track was imported before.
    --dry-run         Resolve and show metadata; download/import nothing.
    --quiet           Suppress info banners and per-track status lines
                      (errors are still printed).
    --verbose         Surface yt-dlp/ffmpeg stderr for troubleshooting.
    --no-progress     Use the indeterminate spinner instead of yt-dlp's real
                      download bar (the bar is on by default at a TTY; also
                      via ADDSONG_PROGRESS=0).
    --format FMT      Output audio format: m4a, mp3, flac, opus, wav, aac
                      (default: m4a; overrides ADDSONG_AUDIO_FORMAT).
    --quality N       Audio quality 0-10, 0=best (default: 0; overrides
                      ADDSONG_AUDIO_QUALITY).
    --no-color        Disable colored output (also honors NO_COLOR).
    --notify          Fire a desktop notification as each track is imported
                      (also via ADDSONG_NOTIFY=1). No-op if no notifier is
                      installed (terminal-notifier/osascript, notify-send).
    -h, --help        Show this help.
    --version         Print the version and exit.

ARGUMENTS:
    <url-or-query>    A YouTube (or other yt-dlp-supported) URL, or -- with
                      --search / by default -- a free-text search query.
                      Examples:
                        addsong "https://www.youtube.com/watch?v=..."
                        addsong "queen bohemian rhapsody"
                        addsong --search 3 "80s disco mix"

INTERACTIVE REVIEW:
    For a single track in a terminal, $PROG shows the scraped artist and title
    and lets you accept them (Enter), edit them (e), or skip (s) before import.
    Playlists default to non-interactive; use --edit to review each track,
    or -y to silence the prompt entirely.

ENVIRONMENT:
    ADDSONG_WATCH_DIR       Override the Apple Music watch folder path.
    ADDSONG_AUDIO_FORMAT    Output audio format (default: m4a); see --format.
    ADDSONG_AUDIO_QUALITY   Audio quality 0-10, 0=best (default: 0); see --quality.
    ADDSONG_LEDGER          Path to the imported-tracks ledger (dedup).
    ADDSONG_SUBSCRIPTIONS   Path to the subscribed-playlists file
                            (default: ~/.local/state/addsong/subscribed.tsv).
    ADDSONG_RETRIES         Extra attempts on transient failures (default: 2).
    ADDSONG_RETRY_DELAY     Base backoff seconds between attempts (default: 3).
    ADDSONG_PROGRESS        Set to 0 to disable the real download bar and use
                            the spinner (same as --no-progress).
    ADDSONG_NOTIFY          Set to 1 to fire a desktop notification per imported
                            track (same as --notify).
    ADDSONG_CONFIG          Config file of KEY=VALUE defaults
                            (default: ~/.config/addsong/config).

EXAMPLES:
    $PROG "https://www.youtube.com/watch?v=..."
    $PROG "queen bohemian rhapsody"
    $PROG --search 3 "80s disco mix"
    $PROG --playlist "https://www.youtube.com/playlist?list=PL..."
    $PROG subscribe "https://www.youtube.com/playlist?list=PL..."
    $PROG sync -y            # import new tracks from subscriptions, no prompts
    $PROG -y "https://youtu.be/..."
    $PROG --dry-run "https://youtu.be/..."
    $PROG --from songs.txt
    pbpaste | $PROG --from -
EOF
}

# Clean a metadata string: drop "(Official Video)", "[4K]", "(feat. X)",
# trailing/leading separators and "- Topic", then collapse whitespace.
clean_meta() {
  perl -CSD -pe '
    BEGIN { binmode STDIN, ":utf8"; binmode STDOUT, ":utf8"; }
    # Remove bracketed junk segments, repeating until none remain.
    1 while s/\s*[\(\[][^\)\]]*\b(?:official(?:\s+(?:music\s+)?video|\s+audio|\s+lyrics?|\s+visualizer)?|music\s+video|lyrics?|audio|video|visualizer|hd|hq|full\s*hd|4k|8k|full\s+album|mv|m\/v|explicit|clean|remaster(?:ed)?(?:\s+\d{4})?)[^\)\]]*[\)\]]//gix;
    s/\s*[\(\[]\s*(?:ft\.?|feat\.?)[^\)\]]*[\)\]]//gi;  # (feat. X) / [ft X]
    s/\s*-\s*topic\s*$//i;                              # "Artist - Topic"
    s/\s*[-\x{2013}|]\s*$//;                            # trailing separator
    s/^\s*[-\x{2013}|]\s*//;                            # leading separator
    s/\s{2,}/ /g; s/^\s+//; s/\s+$//;
  '
}

# Make a string safe to use as a filename (no path separators or colons).
safe_name() {
  local s="$1"
  s="${s//\//_}"    # forward slash
  s="${s//:/_}"     # colon
  s="${s//\\/_}"    # backslash
  printf '%s' "$s"
}

# Detect the host platform. Returns one of: mac / win / wsl / linux / other.
# Pure: reads $OSTYPE and (on Linux) the kernel release for the WSL signature.
detect_os() {
  case "${OSTYPE:-}" in
    darwin*)            echo mac ;;
    msys*|cygwin*)      echo win ;;
    linux*)
      if [[ -r /proc/sys/kernel/osrelease ]] \
         && grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null; then
        echo wsl
      else
        echo linux
      fi
      ;;
    *)                  echo other ;;
  esac
}

# Default watch folder per OS. On mac this is Apple Music's autoscan folder;
# on win/wsl it probes the Apple Music preview app then legacy iTunes, falling
# back to the preview path if neither exists yet (preflight guides the user);
# on linux/other (no Apple Music app) it returns an output-only folder.
default_watch_dir() {
  local os d base
  os="${OS_MODE:-$(detect_os)}"
  case "$os" in
    mac)
      printf '%s\n' \
        "$HOME/Music/Music/Media.localized/Automatically Add to Music.localized" ;;
    win)
      base="${USERPROFILE:-$HOME}"
      for d in \
        "$base/Music/Apple Music/Media/Automatically Add to Apple Music" \
        "$base/Music/iTunes/iTunes Media/Automatically Add to iTunes"; do
        [[ -d "$d" ]] && { printf '%s\n' "$d"; return 0; }
      done
      # Neither found -- return the documented default; preflight guides the
      # user to open the Apple Music preview app once (which creates it).
      printf '%s\n' \
        "$base/Music/Apple Music/Media/Automatically Add to Apple Music"
      ;;
    wsl)
      # Match /mnt/<drive>/Users/<user>/Music/Apple Music/Media/... (or iTunes)
      for d in \
        /mnt/[c-z]/Users/*/Music/Apple\ Music/Media/Automatically\ Add\ to\ Apple\ Music \
        /mnt/[c-z]/Users/*/Music/iTunes/iTunes\ Media/Automatically\ Add\ to\ iTunes; do
        [[ -d "$d" ]] && { printf '%s\n' "$d"; return 0; }
      done
      # No Windows Apple Music library reachable -- output-only fallback.
      printf '%s\n' "${HOME:-/tmp}/Music/addsong" ;;
    *)
      # linux and any other platform: no Apple Music app, output to a folder.
      printf '%s\n' "${HOME:-/tmp}/Music/addsong" ;;
  esac
}

ledger_has() {
  [[ -f "$LEDGER" ]] || return 1
  awk -F'\t' -v id="$1" '$1==id { found=1 } END { exit found?0:1 }' "$LEDGER"
}

ledger_add() {
  mkdir -p "$(dirname "$LEDGER")"
  printf '%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$(date +%FT%T)" >> "$LEDGER"
}

# Forget every imported track: remove the ledger so future runs treat each
# track as new again (re-downloading/re-importing on the next add or sync).
# Destructive, so confirm at a TTY unless -y/--yes was given; refuse without a
# TTY when unconfirmed so a stray `clear-ledger` in a script can't wipe it.
ledger_clear() {
  if [[ ! -s "$LEDGER" ]]; then
    printf 'Ledger is already empty (nothing imported yet).\n'
    return 0
  fi
  local n ans
  n="$(grep -c '' "$LEDGER" 2>/dev/null || echo 0)"
  if [[ "$ASSUME_YES" -ne 1 ]]; then
    if { true; } 2>/dev/null <>/dev/tty; then
      printf 'Clear %s imported track(s) from the ledger? Future runs may re-import them. [y/N] ' \
        "$n" > /dev/tty
      read -r ans < /dev/tty || ans=""
      case "$ans" in
        y|Y|yes|YES) ;;
        *) printf 'Cancelled. Ledger left untouched.\n'; return 0 ;;
      esac
    else
      die "refusing to clear the ledger without confirmation (re-run with -y to confirm)"
    fi
  fi
  rm -f "$LEDGER"
  status "Cleared" "$n track(s) from the ledger"
}

# --- Subscriptions ----------------------------------------------------------
# subscribed.tsv is one URL per line (# comments allowed). 'sync' expands each
# URL like --playlist does; the importer ledger (above) is what makes a sync
# "only import new tracks" -- no per-URL last-seen marker is stored here.

# Add a URL to the subscription list (no-op duplicate).
subs_add() {
  local url="$1"
  [[ "$url" == http://* || "$url" == https://* ]] \
    || die "subscribe needs a URL (got: '$url')"
  mkdir -p "$(dirname "$SUBSCRIPTIONS")"
  [[ -f "$SUBSCRIPTIONS" ]] || : > "$SUBSCRIPTIONS"
  if grep -qxF -- "$url" "$SUBSCRIPTIONS" 2>/dev/null; then
    status "Already subscribed:" "$url"
    return 0
  fi
  printf '%s\n' "$url" >> "$SUBSCRIPTIONS"
  status "Subscribed:" "$url"
}

# Remove a URL from the subscription list (idempotent whether or not present).
subs_remove() {
  local url="$1"
  [[ -f "$SUBSCRIPTIONS" ]] || { status "Not subscribed:" "$url"; return 0; }
  local tmp
  tmp="$(mktemp)"
  # Drop exact-match lines; keep everything else (incl. comments).
  grep -vxF -- "$url" "$SUBSCRIPTIONS" > "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$SUBSCRIPTIONS"
  status "Unsubscribed:" "$url"
}

# Print one subscribed URL per line (comments/blanks skipped), or a hint.
subs_list() {
  if [[ ! -s "$SUBSCRIPTIONS" ]]; then
    printf 'No subscriptions yet. Try: %s subscribe "https://www.youtube.com/playlist?list=..."\n' "$PROG"
    return 0
  fi
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    printf '%s\n' "$line"
  done < "$SUBSCRIPTIONS"
}

# Iterate every subscribed playlist URL, expand it, and import only tracks not
# already in the ledger (the ledger is the dedup source of truth). Composes
# with --dry-run / --force / --edit / -y like a normal playlist run.
subs_sync() {
  [[ -s "$SUBSCRIPTIONS" ]] \
    || { err "no subscriptions yet -- see '$PROG list'"; exit 1; }

  local url ids rev
  rev="$(interactive_for 1)"
  while IFS= read -r url; do
    [[ -z "$url" || "$url" == \#* ]] && continue
    say ""
    say "${PFX_BANNER}Syncing: $url"
    ids="$(yt-dlp --flat-playlist --print '%(id)s' -- "$url" 2>/dev/null)" \
      || { err "could not read playlist: $url"; N_FAILED=$((N_FAILED+1)); continue; }
    if [[ -z "$ids" ]]; then
      err "no tracks found in playlist: $url"
      N_FAILED=$((N_FAILED+1))
      continue
    fi
    run_url_stream "$rev" \
      <<< "$(printf '%s\n' "$ids" | sed '/^$/d; s#^#https://www.youtube.com/watch?v=#')"
  done < "$SUBSCRIPTIONS"
  finish_batch
}

# Run yt-dlp with bounded retry. Stdout goes to file $1, stderr to file $2,
# remaining args are passed through. Transient (network) failures are retried
# with linear backoff; permanent failures (see YTDLP_HARD_ERRORS) return at once.
run_ytdlp() {
  local out="$1" errf="$2"; shift 2
  local attempt=0 rc
  while :; do
    # Capture yt-dlp's own exit status. (`rc=$?` after an `if` would read the
    # if-statement's status -- 0 when the condition is false -- not yt-dlp's.)
    rc=0
    yt-dlp "$@" >"$out" 2>"$errf" || rc=$?
    if [[ "$rc" -eq 0 ]]; then
      [[ "$VERBOSE" -eq 1 && -s "$errf" ]] && cat "$errf" >&2
      return 0
    fi
    [[ "$VERBOSE" -eq 1 && -s "$errf" ]] && cat "$errf" >&2
    if grep -qiE "$YTDLP_HARD_ERRORS" "$errf"; then return "$rc"; fi
    attempt=$((attempt + 1))
    [[ "$attempt" -gt "$RETRIES" ]] && return "$rc"
    err "transient error, retrying ($attempt/$RETRIES) in $((attempt * RETRY_DELAY))s..."
    sleep "$((attempt * RETRY_DELAY))"
  done
}

# Run a command while showing an animated spinner on /dev/tty, then clear the
# line. The command's own stdout/stderr are untouched (callers capture them to
# files), so this is purely cosmetic progress feedback.
#   $1 = label shown next to the spinner; remaining args = the command to run.
# Falls back to running the command synchronously (no spinner) when there is no
# TTY, under --quiet, or under --verbose (so passed-through output stays clean).
with_spinner() {
  local label="$1"; shift
  if [[ "$have_tty" -eq 0 || "$QUIET" -eq 1 || "$VERBOSE" -eq 1 ]]; then
    "$@"
    return $?
  fi
  local -a frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  "$@" &
  local pid=$! i=0 rc=0
  # Hide the cursor while spinning; restore it when we're done.
  printf '\033[?25l' > /dev/tty
  while kill -0 "$pid" 2>/dev/null; do
    printf '\r  %s%s%s %s' "$C_ACCENT" "${frames[i++ % ${#frames[@]}]}" "$C_RESET" "$label" > /dev/tty
    sleep 0.1
  done
  wait "$pid" || rc=$?
  printf '\r\033[K\033[?25h' > /dev/tty   # clear the line and show the cursor
  return "$rc"
}

# Read yt-dlp's --newline progress on stdin and paint an in-place
# percent/speed/ETA bar on /dev/tty for one track. Lines that aren't a
# "[download] ...%" progress update are ignored; the line is cleared when the
# stream closes. Used only in progress mode (a TTY, not --quiet/--verbose; see
# process_one), wired through a process substitution so run_ytdlp's retry +
# stderr-capture wrapper stays untouched.
#   $1 = label shown next to the bar.
render_progress() {
  local label="$1" line body pct ipct eta speed bar metrics i width=24 filled
  local cols avail shown

  # Terminal width: prefer COLUMNS, else ask the tty, else assume 80. We keep
  # the whole painted line within one row (and one column shy of the right edge)
  # so the carriage return below redraws it in place. A line as wide as the
  # terminal triggers the auto-margin wrap, and \r would then only rewrite the
  # last visual row -- leaving the rest stacked as extra lines.
  cols="${COLUMNS:-}"
  [[ "$cols" =~ ^[0-9]+$ ]] \
    || cols="$( { stty size </dev/tty; } 2>/dev/null | awk '{print $2}' )"
  [[ "$cols" =~ ^[0-9]+$ ]] || cols=80

  printf '\033[?25l' > /dev/tty                 # hide cursor while painting
  while IFS= read -r line; do
    [[ "$line" == "[download]"*%* ]] || continue
    body="${line#\[download\]}"
    body="${body#"${body%%[![:space:]]*}"}"     # trim leading whitespace
    pct="${body%%%*}"                            # the number before the first %
    ipct="${pct%.*}"                             # integer part drives the bar
    [[ "$ipct" =~ ^[0-9]+$ ]] || continue
    (( ipct > 100 )) && ipct=100
    eta=""
    [[ "$line" == *" ETA "* ]] && eta="${line##* ETA }"
    speed=""
    if [[ "$line" == *" at "* ]]; then
      speed="${line#* at }"
      speed="${speed%%/s*}"
      speed="${speed#"${speed%%[![:space:]]*}"}/s"
    fi

    # Right-hand stats as one plain string (drives both width math and output).
    printf -v metrics '%5s%%' "$pct"
    [[ -n "$speed" ]] && metrics+="  $speed"
    [[ -n "$eta"   ]] && metrics+="  ETA $eta"

    # On a narrow terminal even the bar + metrics can overflow, so shrink the
    # bar to whatever space is left after the fixed parts (2 indent + 2 spaces +
    # metrics + 1 right margin), keeping at least one cell.
    width=24
    local maxbar=$(( cols - 2 - 1 - 1 - ${#metrics} - 1 ))
    (( maxbar < 1 )) && maxbar=1
    (( width > maxbar )) && width=$maxbar

    # Trim the label so "  <label> <bar> <metrics>" fits one row with a spare
    # column on the right (2 indent + label + 1 space + bar(width) + 1 space +
    # metrics + 1 margin). The bar's color codes are zero-width, so only its
    # `width` cells count.
    avail=$(( cols - 2 - 1 - width - 1 - ${#metrics} - 1 ))
    (( avail < 0 )) && avail=0
    shown="$label"
    if (( ${#shown} > avail )); then
      (( avail >= 1 )) && shown="${label:0:avail-1}…" || shown=""
    fi

    filled=$(( ipct * width / 100 ))
    if [[ -n "$C_BAR_FILL" ]]; then
      # Solid two-tone rectangle: green-filled cells over a gray track. Spaces
      # painted with background colors render as one chunky growing bar.
      local fillstr emptystr
      printf -v fillstr  '%*s' "$filled"            ''
      printf -v emptystr '%*s' "$(( width - filled ))" ''
      bar="${C_BAR_FILL}${fillstr}${C_BAR_TRACK}${emptystr}${C_RESET}"
    else
      # No color (NO_COLOR / --no-color): fall back to plain block characters.
      bar=""
      for ((i = 0; i < width; i++)); do
        (( i < filled )) && bar+="█" || bar+="░"
      done
    fi

    # Carriage return + clear-to-end-of-line repaints this single row in place.
    # The label is painted green (color codes are zero-width, so the width math
    # above is unaffected); empty codes leave it plain under --no-color.
    printf '\r\033[K  %s%s%s %s %s' "$C_S_ADDED" "$shown" "$C_RESET" "$bar" "$metrics" > /dev/tty
  done
  printf '\r\033[K\033[?25h' > /dev/tty          # clear the line, restore cursor
}

# Interactive review. Reads/writes /dev/tty so it works mid-pipeline.
# Sets globals REVIEW_ARTIST / REVIEW_TITLE; returns 1 if the user skips.
review_meta() {
  local id="$1" ans x
  REVIEW_ARTIST="$2"
  REVIEW_TITLE="$3"

  while :; do
    {
      printf '\n'
      printf '  %sReview track %s%s\n' "$C_HEADER" "$GLYPH_NOTE" "$C_RESET"
      printf '  %s%-8s%s%s\n' "$C_ARTIST" 'Artist:' "$C_RESET" "$REVIEW_ARTIST"
      printf '  %s%-8s%s%s%s%s\n' "$C_TITLE" 'Title:'  "$C_RESET" "$C_BOLD" "$REVIEW_TITLE" "$C_RESET"
      printf '\n'
      printf '  %s[Enter]%s Add  %s·%s  %s[E]%s Edit  %s·%s  %s[S]%s Skip\n' \
        "$C_S_ADDED" "$C_RESET" "$C_DIM" "$C_RESET" \
        "$C_ACCENT"  "$C_RESET" "$C_DIM" "$C_RESET" \
        "$C_S_SKIPPED" "$C_RESET"
      printf '  %s❯%s ' "$C_PROMPT" "$C_RESET"
    } > /dev/tty
    read -r ans < /dev/tty || ans=""

    # On Enter/skip the terminal has echoed a newline, leaving the "> " prompt
    # lingering on the row above. Step back up and clear it so the result line
    # follows cleanly.
    case "$ans" in
      ""|y|Y) printf '\033[A\033[2K\r' > /dev/tty; return 0 ;;
      s|S)    printf '\033[A\033[2K\r' > /dev/tty; return 1 ;;
      e|E)
        printf '\n  %sEdit (blank keeps the current value)%s\n' "$C_HINT" "$C_RESET" > /dev/tty
        printf '  %sArtist%s [%s]: ' "$C_ARTIST" "$C_RESET" "$REVIEW_ARTIST" > /dev/tty
        read -r x < /dev/tty || x=""
        [[ -n "$x" ]] && REVIEW_ARTIST="$x"
        printf '  %sTitle%s  [%s]: ' "$C_TITLE" "$C_RESET" "$REVIEW_TITLE" > /dev/tty
        read -r x < /dev/tty || x=""
        [[ -n "$x" ]] && REVIEW_TITLE="$x"
        ;;  # loop to re-show the updated values for confirmation
      *)
        printf '  %s(Enter = Add, E = Edit, S = Skip)%s\n' "$C_DIM" "$C_RESET" > /dev/tty
        ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Process a single track URL.
#   $1 = url, $2 = interactive (1/0)
# Returns: 0 added, 2 skipped (duplicate or user skip), 1 failed.
# ---------------------------------------------------------------------------
process_one() {
  local url="$1" interactive="$2"
  local meta id raw_title raw_uploader artist title album year track_no
  local m_track m_artist m_album m_year m_trackno
  local metaf errf reason

  metaf="$(mktemp "${TMPDIR:-/tmp}/addsong.meta.XXXXXX")"
  errf="$(mktemp "${TMPDIR:-/tmp}/addsong.err.XXXXXX")"
  if ! with_spinner "Reading info" \
        run_ytdlp "$metaf" "$errf" --no-playlist --retries 3 --socket-timeout 30 \
        --print '%(id)s' --print '%(title)s' --print '%(uploader)s' \
        --print '%(track)s' --print '%(artist)s' --print '%(album)s' \
        --print '%(release_year)s' --print '%(track_number)s' -- "$url"; then
    reason="$(grep -i 'error' "$errf" | tail -n1)"
    reason="${reason:-private, removed, region-locked, or age-gated?}"
    err "could not read info for: $url ($reason)"
    rm -f "$metaf" "$errf"
    return 1
  fi
  meta="$(cat "$metaf")"
  rm -f "$metaf" "$errf"

  { read -r id; read -r raw_title; read -r raw_uploader
    read -r m_track; read -r m_artist; read -r m_album
    read -r m_year; read -r m_trackno; } <<< "$meta"
  [[ -n "$id" ]] || { err "no video id for: $url"; return 1; }

  # yt-dlp prints "NA" for missing fields; treat that as empty.
  local v
  for v in m_track m_artist m_album m_year m_trackno; do
    [[ "${!v}" == "NA" ]] && printf -v "$v" '%s' ''
  done

  if [[ -n "$m_track" && -n "$m_artist" ]]; then
    # Structured music metadata (e.g. YouTube Music) -- already clean.
    artist="$m_artist"
    title="$m_track"
  else
    # Heuristic: split "Artist - Title", else fall back to the uploader.
    if [[ "$raw_title" == *" - "* ]]; then
      artist="${raw_title%% - *}"
      title="${raw_title#* - }"
    else
      artist="$raw_uploader"
      title="$raw_title"
    fi
    artist="$(printf '%s' "$artist" | clean_meta)"
    title="$(printf '%s'  "$title"  | clean_meta)"
  fi
  [[ -n "$title" ]] || title="$raw_title"   # never end up with an empty title

  album="$m_album"
  year="$m_year"
  track_no="$m_trackno"

  # Duplicate guard.
  if [[ "$FORCE" -ne 1 ]] && ledger_has "$id"; then
    status "Skipped" "$artist - $title (already imported)"
    return 2
  fi

  # Interactive review.
  if [[ "$interactive" -eq 1 ]]; then
    if review_meta "$id" "$artist" "$title"; then
      artist="$REVIEW_ARTIST"; title="$REVIEW_TITLE"
    else
      status "Skipped" "$artist - $title"
      return 2
    fi
  fi

  # Dry run: report what would be imported, then stop (no download, no ledger).
  if [[ "$DRYRUN" -eq 1 ]]; then
    status "Would add" "$artist - $title"
    [[ -n "$album" || -n "$year" || -n "$track_no" ]] &&
      printf '           album=%s  year=%s  track=%s\n' \
        "${album:-—}" "${year:-—}" "${track_no:-—}"
    return 0
  fi

  # Download audio and artwork into a temp staging dir. In progress mode (see
  # PROGRESS) we paint yt-dlp's real percent/speed/ETA bar; otherwise the
  # indeterminate spinner. Both share one yt-dlp argument list.
  local staging staged final dl_rc
  staging="$(mktemp -d "${TMPDIR:-/tmp}/addsong.XXXXXX")"

  local -a dlargs=(
    --no-playlist --retries 3 --fragment-retries 3 --socket-timeout 30
    --extract-audio --audio-format "$AUDIO_FORMAT" --audio-quality "$AUDIO_QUALITY"
    --embed-thumbnail --convert-thumbnails jpg
    -o "$staging/%(id)s.%(ext)s"
    -- "$url"
  )

  if [[ "$PROGRESS" -eq 1 && "$have_tty" -eq 1 && "$QUIET" -ne 1 && "$VERBOSE" -ne 1 ]]; then
    # --newline makes yt-dlp emit one progress line per update on stdout; route
    # that stdout into render_progress through a process substitution. The fd is
    # opened once here and survives run_ytdlp's retries (each attempt just dups
    # it), so the wrapper's retry + stderr-capture path is untouched. A fixed fd
    # (9) is used rather than the `{var}>` auto-fd form, which needs bash 4.1+
    # (macOS still ships bash 3.2).
    local ppid
    exec 9> >(render_progress "Downloading: $artist - $title")
    ppid=$!
    run_ytdlp "/dev/fd/9" "$staging/dl.err" --progress --newline "${dlargs[@]}" \
      && dl_rc=0 || dl_rc=$?
    exec 9>&-                             # close write end so the bar drains/clears
    wait "$ppid" 2>/dev/null || true
  else
    with_spinner "Downloading: $artist - $title" \
      run_ytdlp /dev/null "$staging/dl.err" "${dlargs[@]}" \
      && dl_rc=0 || dl_rc=$?
  fi

  if [[ "$dl_rc" -ne 0 ]]; then
    err "download failed: $artist - $title ($(grep -i 'error' "$staging/dl.err" | tail -n1))"
    rm -rf "$staging"
    return 1
  fi

  staged="$staging/$id.$AUDIO_FORMAT"
  if [[ ! -s "$staged" ]]; then
    err "no .$AUDIO_FORMAT produced for: $artist - $title"
    rm -rf "$staging"
    return 1
  fi

  # Write the chosen tags (copies all streams, so embedded artwork is kept).
  # Album / year / track number are only written when yt-dlp supplied them.
  final="$staging/out.$AUDIO_FORMAT"
  local -a tagargs
  tagargs=(-metadata title="$title"
           -metadata artist="$artist"
           -metadata album_artist="$artist")
  [[ -n "$album" ]]    && tagargs+=(-metadata album="$album")
  [[ -n "$year" ]]     && tagargs+=(-metadata date="$year")
  [[ -n "$track_no" ]] && tagargs+=(-metadata track="$track_no")

  if ! ffmpeg -y -loglevel error -i "$staged" -map 0 -c copy \
        "${tagargs[@]}" \
        "$final" >/dev/null 2>"$staging/ff.err"; then
    err "tagging failed: $artist - $title ($(grep -i 'error' "$staging/ff.err" | tail -n1))"
    rm -rf "$staging"
    return 1
  fi
  [[ "$VERBOSE" -eq 1 && -s "$staging/ff.err" ]] && cat "$staging/ff.err" >&2
  if [[ ! -s "$final" ]]; then
    err "tagging produced an empty file: $artist - $title"
    rm -rf "$staging"
    return 1
  fi

  # Move into the watch folder; Apple Music imports it from there.
  local dest
  dest="$WATCH_DIR/$(safe_name "$artist - $title").$AUDIO_FORMAT"
  if [[ -e "$dest" ]]; then
    dest="$WATCH_DIR/$(safe_name "$artist - $title") ($(date +%s)).$AUDIO_FORMAT"
  fi

  if ! mv -f "$final" "$dest"; then
    err "could not move into watch folder (permission?): $artist - $title"
    rm -rf "$staging"
    return 1
  fi
  rm -rf "$staging"

  ledger_add "$id" "$artist" "$title"
  status "Added" "$artist - $title"
  notify "Added to Apple Music" "$artist - $title"
  return 0
}

# ---------------------------------------------------------------------------
# Decide whether to review interactively.
#   --edit forces on; -y forces off; otherwise on for a single track at a TTY.
# ---------------------------------------------------------------------------
interactive_for() {
  # $1 = is this a playlist run? (1/0); reads the global have_tty.
  if [[ "$DRYRUN" -eq 1 ]]; then echo 0; return; fi      # nothing to confirm
  if [[ "$ASSUME_YES" -eq 1 ]]; then echo 0; return; fi
  if [[ "$EDIT_FORCE" -eq 1 ]]; then echo "$have_tty"; return; fi
  if [[ "$1" -eq 1 ]]; then echo 0; return; fi   # playlists default to no prompt
  echo "$have_tty"
}

note_imported() {
  # $1 = how many were added
  [[ "$DRYRUN" -eq 1 ]] && return 0
  [[ "$1" -gt 0 ]] || return 0
  case "${OS_MODE:-}" in
    mac|win|wsl)
      say ""
      say "Apple Music will import shortly. Make sure the Music app is open." ;;
  esac
}

# Process a stream of URLs (one per line on stdin), updating the run tallies.
# Must be fed via here-string / redirection (not a pipe) so the counts persist.
#   $1 = interactive flag
run_url_stream() {
  local rev="$1" line rc
  while IFS= read -r line; do
    line="${line#"${line%%[![:space:]]*}"}"   # trim leading whitespace
    line="${line%"${line##*[![:space:]]}"}"   # trim trailing whitespace
    [[ -z "$line" || "$line" == \#* ]] && continue
    process_one "$line" "$rev" && rc=0 || rc=$?
    case "$rc" in
      0) N_ADDED=$((N_ADDED+1)) ;;
      2) N_SKIPPED=$((N_SKIPPED+1)) ;;
      *) N_FAILED=$((N_FAILED+1)) ;;
    esac
  done
}

# Print the end-of-run summary and exit (non-zero if anything failed).
finish_batch() {
  local verb="Added"
  [[ "$DRYRUN" -eq 1 ]] && verb="Would add"
  # A clean failure count stays dim; once something fails it turns red. With
  # colors off every code is empty, so the line is the same plain summary.
  local fcolor="$C_DIM"
  [[ "$N_FAILED" -gt 0 ]] && fcolor="$C_S_FAILED"
  say ""
  say "$(printf 'Done. %s %s%s%s, skipped %s%s%s, failed %s%s%s.' \
    "$verb" \
    "$C_S_ADDED"   "$N_ADDED"   "$C_RESET" \
    "$C_S_SKIPPED" "$N_SKIPPED" "$C_RESET" \
    "$fcolor"      "$N_FAILED"  "$C_RESET")"
  note_imported "$N_ADDED"
  [[ "$N_FAILED" -gt 0 ]] && exit 1 || exit 0
}

# ---------------------------------------------------------------------------
# main: parse arguments, run preflight checks, and process the request.
# Kept in a function (and gated by the source guard at the bottom) so the file
# can be `source`d by tests to exercise the functions above without parsing
# args, running preflight, or downloading anything.
# ---------------------------------------------------------------------------
main() {
  local URL="" tool ids rev rc

  # Subcommand peek: a bare first arg of subscribe/unsubscribe/list/sync isn't
  # a URL or a YouTube search (URLs always start with http(s)://), so intercept
  # it as the verb rather than routing it into the search/URL path below.
  case "${1:-}" in
    subscribe|unsubscribe|list|sync|clear-ledger)
      SUBCMD="$1"; shift
      # If this is the very first thing and the help/version flags alone were
      # requested, honour them immediately.
      [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
      [[ "${1:-}" == "--version" ]] && { printf '%s %s\n' "$PROG" "$VERSION"; exit 0; }
      ;;
  esac

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)   usage; exit 0 ;;
      --version)   printf '%s %s\n' "$PROG" "$VERSION"; exit 0 ;;
      --playlist)  PLAYLIST=1 ;;
      -y|--yes)    ASSUME_YES=1 ;;
      --edit)      EDIT_FORCE=1 ;;
      --force)     FORCE=1 ;;
      --dry-run)   DRYRUN=1 ;;
      --quiet)     QUIET=1 ;;
      --verbose)   VERBOSE=1 ;;
      --no-color)  NO_COLOR_FLAG=1 ;;
      --notify)    NOTIFY=1 ;;
      --no-progress) PROGRESS=0 ;;
      --format)    AUDIO_FORMAT="${2:-}"; [[ -n "$AUDIO_FORMAT" ]] || die "--format needs a value (e.g. --format mp3)"
                   [[ " $AUDIO_FORMATS " == *" $AUDIO_FORMAT "* ]] \
                     || die "--format must be one of: $AUDIO_FORMATS (got: '$AUDIO_FORMAT')"
                   shift ;;
      --quality)   AUDIO_QUALITY="${2:-}"; [[ -n "$AUDIO_QUALITY" ]] || die "--quality needs a number 0-10 (0=best)"
                   { [[ "$AUDIO_QUALITY" =~ ^[0-9]+$ ]] && (( AUDIO_QUALITY <= 10 )); } \
                     || die "--quality must be an integer 0-10 (got: '$AUDIO_QUALITY')"
                   shift ;;
      --search)    SEARCH="${2:-}"; [[ -n "$SEARCH" ]] || die "--search needs a number (e.g. --search 3)"
                   [[ "$SEARCH" =~ ^[1-9][0-9]*$ ]] || die "--search needs a positive integer (got: '$SEARCH')"
                   (( SEARCH <= 50 )) || die "--search is capped at 50 (use a playlist URL for more)"
                   shift ;;
      --from)      FROM_FILE="${2:-}"; [[ -n "$FROM_FILE" ]] || die "--from needs a file (or - for stdin)"; shift ;;
      --)          shift; URL="${1:-}"; break ;;
      -*)          die "unknown option: $1 (try --help)" ;;
      *)           URL="$1" ;;
    esac
    shift
  done

  # Acknowledge subcommands before the URL/search validation below, because
  # list/sync don't take a <url> argument at all and would otherwise trip the
  # "expected a URL" guard.
  if [[ -n "$SUBCMD" ]]; then
    case "$SUBCMD" in
      subscribe)   [[ -n "$URL" ]] || die "subscribe needs a URL"; subs_add    "$URL"; exit 0 ;;
      unsubscribe) [[ -n "$URL" ]] || die "unsubscribe needs a URL"; subs_remove "$URL"; exit 0 ;;
      list)        subs_list; exit 0 ;;
      clear-ledger) ledger_clear; exit 0 ;;
      # sync needs preflight (yt-dlp + watch dir); but short-circuit if there
      # are no subscriptions so the user doesn't have to install yt-dlp just
      # to see the friendly "none yet" message.
      sync)
        if [[ ! -s "$SUBSCRIPTIONS" ]]; then
          err "no subscriptions yet -- see '$PROG list'"
          exit 1
        fi
        ;;
    esac
  fi

  # Decide input mode. --from (file), --playlist (URL), --search (free text),
  # or a single URL. They are mutually exclusive. Only the sync subcommand can
  # legitimately have no URL at all here, so skip the guards in that case.
  if [[ -z "$SUBCMD" ]]; then
    if [[ -n "$FROM_FILE" ]]; then
      { [[ "$PLAYLIST" -eq 1 ]] || [[ "$SEARCH" -gt 0 ]]; } && die "--from is exclusive with --playlist/--search"
      [[ -n "$URL" ]] && die "--from is exclusive with a URL/search argument"
    elif [[ "$PLAYLIST" -eq 1 ]]; then
      [[ "$SEARCH" -gt 0 ]] && die "--playlist is exclusive with --search"
      [[ -z "$URL" ]] && die "--playlist needs a URL"
      [[ "$URL" != http://* && "$URL" != https://* ]] && die "--playlist needs a URL (got: '$URL')"
    elif [[ "$SEARCH" -gt 0 ]]; then
      [[ -z "$URL" ]] && die "--search needs a query (try: $PROG --search 3 \"80s disco mix\")"
      [[ "$URL" == http://* || "$URL" == https://* ]] && die "--search and a URL are mutually exclusive"
    elif [[ -z "$URL" ]]; then
      usage >&2; exit 1
    elif [[ "$URL" != http://* && "$URL" != https://* ]]; then
      # Default: a bare non-URL argument is a 1-result YouTube search.
      SEARCH=1
    fi
  fi

  # Resolve platform + watch folder. ADDSONG_WATCH_DIR always wins.
  OS_MODE="$(detect_os)"
  WATCH_DIR="${ADDSONG_WATCH_DIR:-$(default_watch_dir)}"

  # Preflight: required tools.
  for tool in yt-dlp ffmpeg; do
    command -v "$tool" >/dev/null 2>&1 \
      || die "'$tool' not found on PATH.
Install yt-dlp and ffmpeg (e.g. brew install yt-dlp ffmpeg on macOS,
choco install yt-dlp ffmpeg on Windows, or use your distro's package manager).
See the Setup section in the README."
  done

  # Preflight: watch folder. mac/win/wsl expect an Apple Music app folder to
  # exist; linux/other run output-only and create the fallback dir themselves.
  if [[ ! -d "$WATCH_DIR" ]]; then
    case "$OS_MODE" in
      mac)
        die "Apple Music watch folder not found:
    $WATCH_DIR
Open Music > Settings > Files to find your 'Music Media folder location',
then set ADDSONG_WATCH_DIR to the 'Automatically Add to Music' folder inside it.
See the Setup section in the README." ;;
      win)
        die "Apple Music watch folder not found:
    $WATCH_DIR
Open the Apple Music preview app (or iTunes) at least once so it creates the
folder, then re-run. Or set ADDSONG_WATCH_DIR to your library's
'Automatically Add to ...' folder. See the Setup section in the README." ;;
      wsl)
        die "Apple Music watch folder not found:
    $WATCH_DIR
Open the Apple Music preview app (or iTunes) in Windows at least once so it
creates the folder. From WSL, point ADDSONG_WATCH_DIR at the Windows path,
e.g. /mnt/c/Users/you/Music/Apple Music/Media/Automatically Add to Apple Music.
See the Setup section in the README." ;;
      *)
        # Output-only: macOS Apple Music app doesn't exist here. Ensure the
        # fallback folder exists and continue; import is the user's job.
        mkdir -p "$WATCH_DIR" \
          || die "cannot create output folder: $WATCH_DIR"
        say "note: output folder is:"
        say "      $WATCH_DIR"
        say "      import files into your library of choice manually." ;;
    esac
  fi

  # Detect a usable controlling terminal by actually opening /dev/tty
  # read-write. The cheaper [[ -e/-r /dev/tty ]] test passes even when there is
  # no controlling terminal (cron, CI, some piped contexts), where opening it
  # fails with ENXIO -- so probe the open, which is what the spinner and the
  # interactive prompts really need. The redirection is on a group command (not
  # exec) so a failure just marks no-TTY instead of exiting the shell.
  have_tty=0
  if { true; } 2>/dev/null <>/dev/tty; then have_tty=1; fi
  setup_colors

  # 'sync' was peeked earlier but needs preflight, so it falls through to here.
  [[ "$SUBCMD" == "sync" ]] && subs_sync

  if [[ -n "$FROM_FILE" ]]; then
    rev="$(interactive_for 1)"   # batch: non-interactive unless --edit
    if [[ "$FROM_FILE" == "-" ]]; then
      run_url_stream "$rev"
    else
      [[ -f "$FROM_FILE" ]] || die "no such file: $FROM_FILE"
      run_url_stream "$rev" < "$FROM_FILE"
    fi
    finish_batch
  elif [[ "$PLAYLIST" -eq 1 ]]; then
    say "${PFX_BANNER}Reading playlist..."
    ids="$(yt-dlp --flat-playlist --print '%(id)s' -- "$URL" 2>/dev/null)" \
      || die "could not read playlist: $URL"
    [[ -n "$ids" ]] || die "no tracks found in playlist: $URL"

    rev="$(interactive_for 1)"
    run_url_stream "$rev" \
      <<< "$(printf '%s\n' "$ids" | sed '/^$/d; s#^#https://www.youtube.com/watch?v=#')"
    finish_batch
  elif [[ "$SEARCH" -gt 0 ]]; then
    say "${PFX_BANNER}Searching YouTube for: $URL"
    ids="$(yt-dlp --flat-playlist --print '%(id)s' -- "ytsearch${SEARCH}:${URL}" 2>/dev/null)" \
      || die "search failed: $URL"
    [[ -n "$ids" ]] || die "no search results for: $URL"

    rev="$(interactive_for 1)"
    run_url_stream "$rev" \
      <<< "$(printf '%s\n' "$ids" | sed '/^$/d; s#^#https://www.youtube.com/watch?v=#')"
    finish_batch
  else
    rev="$(interactive_for 0)"
    process_one "$URL" "$rev" && rc=0 || rc=$?
    case "$rc" in
      0) note_imported 1; exit 0 ;;
      2) exit 0 ;;
      *) exit 1 ;;
    esac
  fi
}

# Run main only when executed directly. When the file is sourced (e.g. by the
# bats tests), this is skipped so only the function definitions are loaded.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
